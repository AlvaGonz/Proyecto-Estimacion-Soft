# EstimaPro — Docker Environment Template
# Copy this file to .env.docker and fill in real values.
# NEVER commit .env.docker — only .env.docker.example is tracked.

# Core configuration
NODE_ENV=development
PORT=4000

# Ports
FRONTEND_PORT=3001
BACKEND_PORT=4000
MONGO_PORT=27017

# Database
MONGO_ROOT_USER=your_mongo_admin_user
MONGO_ROOT_PASS=your_mongo_admin_password
MONGODB_URI=mongodb://your_user:your_password@mongo:27017/estimacion-dev?authSource=admin

# JWT Secrets (min 32 chars each — use: openssl rand -base64 32)
JWT_ACCESS_SECRET=replace_with_min_32_char_random_string
JWT_REFRESH_SECRET=replace_with_different_min_32_char_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Frontend (Vite)
VITE_API_URL=/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
