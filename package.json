{
  "name": "estimapro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vite.config.ts",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:check": "tsx e2e/check-servers.ts",
    "e2e:safe": "tsx e2e/check-servers.ts && playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:reset-auth": "node -e \"require('fs').rmSync('e2e/.auth', { recursive: true, force: true }); console.log('Auth state cleared.')\"",
    "e2e:fresh": "npm run e2e:reset-auth && npm run e2e"
  },
  "dependencies": {
    "@google/genai": "1.44.0",
    "date-fns": "4.1.0",
    "jspdf": "4.2.1",
    "jspdf-autotable": "5.0.7",
    "lucide-react": "0.575.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "react-hot-toast": "2.6.0",
    "recharts": "3.7.0",
    "xlsx": "0.18.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mongodb": "^4.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "10.4.20",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "mongodb": "^7.1.1",
    "postcss": "8.5.3",
    "tailwindcss": "4.2.1",
    "typescript": "5.8.3",
    "vite": "6.4.1",
    "vitest": "^4.0.18"
  }
}
